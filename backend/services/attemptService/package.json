{
    "name": "peerprep-attemptservice",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "predev": "npm run db:migrate",
        "dev": "tsx --watch server.ts",
        "db:migrate": "tsx migrations/migrate.ts",
        "build": "tsc && tsc-alias",
        "start:container": "npm run db:migrate && npm start",
        "start": "node dist/server.js",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts"
    },
    "dependencies": {
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "pg": "^8.16.3",
        "pino": "^9.6.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.15.5",
        "@vitest/coverage-v8": "^4.0.18",
        "pino-pretty": "^13.0.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}
