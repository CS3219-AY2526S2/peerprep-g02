{
    "name": "peerprep-userservice",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "predev": "npm run db:migrate",
        "dev": "tsx --watch server.ts",
        "db:migrate": "tsx migrations/migrate.ts",
        "build": "tsc && tsc-alias",
        "start:container": "npm run db:migrate && npm start",
        "start": "node dist/server.js",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:coverage": "vitest run --coverage --config vitest.config.ts",
        "lint": "eslint .",
        "lint:fix": "prettier --write . && eslint . --fix"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@clerk/express": "^1.7.69",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "helmet": "^7.2.0",
        "pg": "^8.16.3",
        "pino": "^9.6.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.15.5",
        "@types/swagger-ui-express": "^4.1.8",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "pino-pretty": "^13.0.0",
        "prettier": "^3.8.1",
        "tsx": "^4.7.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.0.18"
    }
}
